# Database - replace with your PostgreSQL connection string
DATABASE_URL="postgresql://cmms_user:secure_password@localhost:5433/cmms_db"

# Session secret - change this to any long random string (32+ chars)
SESSION_SECRET="change-this-to-a-very-long-random-secret-string-32chars"



# ─── existing vars ────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ─── email notifications ───────────────────────────────────────────────────────
# Option A: Gmail (enable "App Passwords" in your Google account)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=you@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="CMMS <you@gmail.com>"

# Option B: Mailtrap (free, for development/testing - emails go to inbox, not real people)
# EMAIL_HOST=sandbox.smtp.mailtrap.io
# EMAIL_PORT=2525
# EMAIL_USER=your-mailtrap-user
# EMAIL_PASS=your-mailtrap-pass
# EMAIL_FROM="CMMS <noreply@cmms.local>"

# Option C: No email (leave EMAIL_USER blank - emails silently skipped)
# EMAIL_USER=

# ─── cron job ─────────────────────────────────────────────────────────────────
# Secret token for the overdue digest endpoint
# Call: POST /api/notifications/digest with header: Authorization: Bearer <token>
CRON_SECRET=your-random-cron-secret-here

# ─── file storage (minio) ──────────────────────────────────────────────────────
# MinIO configuration for attachment storage
# For local development: use http://localhost:9000 with default credentials
# For production: use your MinIO/S3 endpoint with secure credentials
MINIO_ENDPOINT=http://localhost:9000
MAX_MINIO_ACCESS_KEY=cmms_user
MAX_MINIO_SECRET_KEY=cmms_password
MINIO_BUCKET_NAME=cmms-attachments
MINIO_REGION=us-east-1
MINIO_USE_SSL=false

FACE_SERVICE_URL=http://localhost:8000